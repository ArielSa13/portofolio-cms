{
  "name": "starter/portfolio-cms",
  "type": "project",
  "description": "Starter Laravel CMS portfolio",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "require-dev": {
    "laravel/pail": "^1.2",
    "nunomaduro/collision": "^8.9",
    "laravel/sail": "^1.57",
    "laravel/tinker": "^3.0",
    "laravel/breeze": "^2.4",
    "pestphp/pest": "*",
    "pestphp/pest-plugin-laravel": "*"
  }
}
